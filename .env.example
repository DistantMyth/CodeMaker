# CodeMaker Configuration
# Copy this file to .env and fill in your values

# Required: Your Google Gemini API key
GEMINI_API_KEY=your_api_key_here

# System prompt sent to Gemini along with the screenshot
SYSTEM_PROMPT=Solve this in c and have no comments at all.

# Trigger key sequence (comma-separated key names)
# Default: triple-tab then triple-backspace
TRIGGER_SEQUENCE=tab,tab,tab,backspace,backspace,backspace

# Gemini model to use
GEMINI_MODEL=gemini-2.0-flash

# Screenshot tool preference: grim, portal, gnome-screenshot, auto
# "auto" tries each in order until one works
SCREENSHOT_TOOL=auto

# Emergency kill combo to instantly exit the service
KILL_COMBO=ctrl+shift+escape

# Linux: path to keyboard device (leave empty for auto-detect)
# e.g., /dev/input/event3
KEYBOARD_DEVICE=
